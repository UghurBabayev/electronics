<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="005-create-sales" author="admin">
        <createTable tableName="sales">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_sale_product"
                             references="products(id)"/>
            </column>
            <column name="customer_id" type="BIGINT">
                <constraints foreignKeyName="fk_sale_customer"
                             references="customers(id)"/>
            </column>
            <column name="sale_price" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="sale_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="payment_type" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="note" type="TEXT"/>
            <column name="created_by" type="BIGINT">
                <constraints foreignKeyName="fk_sale_user"
                             references="users(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>ALTER TABLE sales ADD CONSTRAINT chk_sale_payment_type CHECK (payment_type IN ('CASH', 'CREDIT'))</sql>
    </changeSet>

</databaseChangeLog>