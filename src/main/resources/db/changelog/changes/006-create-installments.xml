<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- Nisiyə planı (hər CREDIT satış üçün bir plan) -->
    <changeSet id="006-create-installment-plans" author="admin">
        <createTable tableName="installment_plans">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sale_id" type="BIGINT">
                <constraints nullable="false" unique="true"
                             foreignKeyName="fk_plan_sale"
                             references="sales(id)"/>
            </column>
            <column name="total_amount" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="monthly_payment" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="duration_months" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="start_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="paid_amount" type="NUMERIC(12,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(15)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>ALTER TABLE installment_plans ADD CONSTRAINT chk_plan_status CHECK (status IN ('ACTIVE', 'COMPLETED', 'OVERDUE'))</sql>
    </changeSet>

    <!-- Ödəniş cədvəli (hər ay üçün bir sətir) -->
    <changeSet id="006-create-installment-payments" author="admin">
        <createTable tableName="installment_payments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="plan_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_payment_plan"
                             references="installment_plans(id)"/>
            </column>
            <column name="due_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="paid_date" type="DATE"/>
            <column name="is_paid" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>