<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="020-create-cash-entries" author="admin">
        <createTable tableName="cash_entries">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="entry_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="amount" type="NUMERIC(12,2)">
                <constraints nullable="false"/>
            </column>
            <column name="note" type="VARCHAR(500)"/>
            <column name="created_by_id" type="BIGINT">
                <constraints foreignKeyName="fk_cash_entry_user" references="users(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="NOW()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>